# brain-server JWT 密钥（请在本地复制为 .env.brain 后修改）
JWT_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# Phase 1 临时启动账号（后续切换为数据库用户）
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_ROLE=super_admin
BOOTSTRAP_ADMIN_PROFILE_ID=profile-admin
RAGFLOW_BASE_URL=http://host.docker.internal:8084
# RAGFLOW_API_KEY=
# RAGFLOW_BEARER_TOKEN=
# RAGFLOW_AUTHORIZATION=Bearer <your-ragflow-token>
RAGFLOW_QUERY_PATH=/api/v1/chats_openai/{chatId}/chat/completions
# RAGFLOW_CHAT_ID=<your-chat-id>
RAGFLOW_MODEL=deepseek-r1-distill-qwen-14b@Xinference
SKILL_FILE_BASE_DIR=/tmp/brain-skill-files
SKILL_INPUT_BASE_DIR=/tmp/brain-skill-files/inputs
SKILL_OUTPUT_BASE_DIR=/tmp/brain-skill-files/outputs
SKILL_INDICATOR_SCRIPT_PATH=/opt/skills/cad_text_extractor/run_skill.py
FILE_STORAGE_BACKEND=local
FILE_S3_ENDPOINT=http://host.docker.internal:9002
FILE_S3_REGION=us-east-1
FILE_S3_ACCESS_KEY_ID=rag_flow
FILE_S3_SECRET_ACCESS_KEY=infini_rag_flow
FILE_S3_BUCKET=brain-skill-files
FILE_S3_FORCE_PATH_STYLE=true
MAINTENANCE_ENABLE_SMOKE=true
MAINTENANCE_INTERVAL_SECONDS=1800
