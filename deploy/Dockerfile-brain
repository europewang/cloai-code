# syntax=docker/dockerfile:1.7

FROM oven/bun:1.3.11 AS deps
WORKDIR /app
# Use minimal base

# Copy dependency files first for Docker layer caching
COPY package.json bun.lock* ./
COPY shims/ ./shims/
RUN --mount=type=cache,target=/root/.bun/install/cache \
  bun install --frozen-lockfile

FROM deps AS build
WORKDIR /app
ARG BUILD_STAMP=dev
RUN echo "$BUILD_STAMP" > /tmp/build_stamp
COPY tsconfig.json ./
COPY src ./src
COPY skills ./skills

FROM oven/bun:1.3.11 AS runtime
WORKDIR /app
ENV NODE_ENV=production
# Install Python3 and dependencies using Chinese mirror
RUN sed -i 's/deb.debian.org/mirrors.tuna.tsinghua.edu.cn/g' /etc/apt/sources.list.d/debian.sources && \
    apt-get update -y && apt-get install -y python3 python3-pip && rm -rf /var/lib/apt/lists/*

# Install CAD skill Python dependencies using Tsinghua mirror
RUN pip3 install -q --break-system-packages -i https://pypi.tuna.tsinghua.edu.cn/simple ezdxf openpyxl

COPY --from=build /app/package.json ./package.json
COPY --from=build /app/bun.lock ./bun.lock
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/src ./src
COPY --from=build /app/skills ./skills
COPY --from=build /app/tsconfig.json ./tsconfig.json

# Create .claude/skills symlink so skill discovery works
RUN mkdir -p /app/.claude && ln -s /app/skills /app/.claude/skills

EXPOSE 3100
CMD ["bun", "run", "src/services/brainOrchestration/brainService.ts"]
