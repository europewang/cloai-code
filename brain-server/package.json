{
  "name": "brain-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "prisma migrate deploy && bun run seed:admin && node dist/index.js",
    "build": "prisma generate && tsc -p tsconfig.json",
    "seed:admin": "node dist/scripts/seedAdmin.js",
    "ops:cleanup-s3-orphans": "bun dist/scripts/cleanupOrphanS3Objects.js",
    "ops:backfill-file-sha256": "bun dist/scripts/backfillFileSha256.js",
    "ops:migrate-local-assets-to-s3": "bun dist/scripts/migrateLocalAssetsToS3.js",
    "ops:maintenance-tick": "bun dist/scripts/maintenanceTick.js",
    "ops:smoke-admin-file-status": "bun dist/scripts/smokeAdminFileStatusApis.js",
    "test:e2e-governance": "python3 test/run_governance_e2e.py",
    "test:e2e-all": "python3 test/run_governance_e2e.py && bun dist/scripts/smokeAdminFileStatusApis.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@fastify/multipart": "^9.0.3",
    "@aws-sdk/client-s3": "^3.821.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "prisma": "^6.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/pg": "^8.15.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
